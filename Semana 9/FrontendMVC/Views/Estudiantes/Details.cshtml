@model Estudiante
@{
    ViewData["Title"] = "Detalle del Estudiante";
}

<h2>Detalle del Estudiante</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.CodEstudiante</dd>

            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.NombreCompleto</dd>

            <dt class="col-sm-3">Carnet</dt>
            <dd class="col-sm-9">@Model.Carnet</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Estado == 1 ? "bg-success" : "bg-secondary")">
                    @Model.EstadoTexto
                </span>
            </dd>

            <dt class="col-sm-3">Fecha Creación</dt>
            <dd class="col-sm-9">@Model.FecCreacion?.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.CodEstudiante" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>
