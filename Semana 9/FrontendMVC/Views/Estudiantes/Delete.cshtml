@model Estudiante
@{
    ViewData["Title"] = "Eliminar Estudiante";
}

<h2>Eliminar Estudiante</h2>

<div class="alert alert-warning">
    ¿Está seguro de que desea eliminar el siguiente estudiante?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.CodEstudiante</dd>

            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.NombreCompleto</dd>

            <dt class="col-sm-3">Carnet</dt>
            <dd class="col-sm-9">@Model.Carnet</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.CodEstudiante" method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
