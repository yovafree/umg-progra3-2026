@model AsignarNotaViewModel
@{
    ViewData["Title"] = "Asignar Nota";
}

<h2>Asignar Nota</h2>
<partial name="_Alerts" />

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <p><strong>Estudiante:</strong> @Model.NombreEstudiante</p>
                <p><strong>Curso:</strong> @Model.NombreCurso</p>
            </div>
        </div>

        <form asp-action="AsignarNota" asp-route-id="@Model.CodInscripcion" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CodInscripcion" />
            <input type="hidden" asp-for="NombreEstudiante" />
            <input type="hidden" asp-for="NombreCurso" />

            <div class="mb-3">
                <label asp-for="Nota" class="form-label"></label>
                <input asp-for="Nota" class="form-control" type="number" step="0.1" min="0" max="100" />
                <span asp-validation-for="Nota" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Guardar Nota</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
