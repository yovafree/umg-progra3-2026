@model Inscripcion
@{
    ViewData["Title"] = "Eliminar Inscripción";
}

<h2>Eliminar Inscripción</h2>

<div class="alert alert-warning">
    ¿Está seguro de que desea eliminar la siguiente inscripción?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.CodInscripcion</dd>

            <dt class="col-sm-3">Estudiante</dt>
            <dd class="col-sm-9">@Model.Estudiante?.NombreCompleto</dd>

            <dt class="col-sm-3">Curso</dt>
            <dd class="col-sm-9">@Model.Curso?.NomCurso</dd>

            <dt class="col-sm-3">Nota Final</dt>
            <dd class="col-sm-9">@(Model.NotaFinal?.ToString("F1") ?? "Sin nota")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.CodInscripcion" method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
